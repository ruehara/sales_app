{
    "files.exclude": {
        "**/*.drift.dart": true,
        "build/": true,
        ".idea/": true,
        ".flutter-plugins": true,
        ".flutter-plugins-dependencies": true,
        ".metadata": true,
        "pubspec.lock": true,
    },
    "editor.codeActionsOnSave": {
        "source.fixAll": "explicit"
    },
    "java.compile.nullAnalysis.mode": "automatic",
    "arb-editor.suppressedWarnings": [
        "missing_metadata_for_key",
    ],
}